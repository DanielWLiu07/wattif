# Backend REST + WS base. Frontend falls back to built-in mock data when unreachable.
VITE_API_URL=http://localhost:8000

# Optional: Mapbox Standard 3D basemap. When set, the map uses Mapbox Standard
# (real 3D buildings + lighting). Leave blank to use the free keyless MapLibre
# (CARTO dark-matter) basemap — the demo works fully without it.
VITE_MAPBOX_TOKEN=

# Optional: Google Photorealistic 3D Tiles overlay (Tile3DLayer).
# Leave blank — baseline runs without any Google key.
VITE_GOOGLE_MAPS_KEY=

# --- Supabase (Phase 2 — NOT required in Phase 1) ------------------------
# Client-side proposal persistence will use these in a later phase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
