# WattIf backend configuration. Copy to .env and fill in as needed.
#
# Phase 1: only LLM and sim vars below are used. Supabase placeholders are for Phase 2
# — leave them blank; the app runs fully without them.

# --- (a) Anthropic (Claude — primary LLM target) -------------------------
ANTHROPIC_API_KEY=
# WATTIF_CLAUDE_MODEL=claude-opus-4-7

# --- (b) OpenAI-compatible gateway (Featherless / Feather fallback) ------
# Set ALL of API_KEY + BASE_URL (and optionally MODEL) to enable this provider.
FEATHER_API_KEY=
FEATHER_BASE_URL=
FEATHER_MODEL=

# --- scripted demo provider ----------------------------------------------
# When NO real key is set, a deterministic scripted "demo" provider drives the agentic
# planner (full tool-calling loop, auto+step) and keeps template-based voices — so the
# whole experience works with no key. A real key above always takes precedence.
# Set to 0 to fall back to the bare deterministic planner-lite instead.
WATTIF_DEMO_LLM=1

# --- Supabase (Phase 2 — NOT required in Phase 1) ------------------------
# Proposal persistence and asset metadata will use these in a later phase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- optional sim/data overrides (sane defaults baked in) ----------------
# WATTIF_LLM_AGENT_SAMPLE=8
# WATTIF_NUM_AGENTS=3000
# WATTIF_SEED=42
# WATTIF_START_YEAR=2025
# WATTIF_TICK_SECONDS=1.0
# WATTIF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
